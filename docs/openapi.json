{
  "openapi": "3.1.0",
  "info": {
    "title": "MobileWallet backend",
    "description": "\nBackend **MobileWallet** — un rassemblement d'**agrégateurs** de paiement Mobile Money.\n\nChaque agrégateur (DigiKUNTZ aujourd'hui, d'autres demain) est un module exposant\ndeux capacités :\n\n- **navigateur IA** (`mode=browser`) : un agent Playwright + LLM pilote le checkout,\n  exécute le paiement et **déduit** le « curl replay » (requête `/charge` + `/verify`),\n  persisté comme *template* réutilisable.\n- **curl replay** (`mode=replay`) : rejoue le paiement sans navigateur via le template stocké.\n- **auto** (`mode=auto`, défaut) : tente le replay d'abord, puis bascule sur le navigateur\n  si le replay est non concluant (`fallback_browser`).\n\nToute tentative est auditée (table `transactions`) quand Supabase est configuré.\n",
    "version": "0.2"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Santé du service",
        "description": "Statut du service + liste des agrégateurs enregistrés.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/aggregators": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Agrégateurs disponibles",
        "description": "Liste les agrégateurs et, pour chacun, les réseaux exacts acceptés.",
        "operationId": "list_aggregators_aggregators_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/config/max-tabs": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Seuil d'onglets par navigateur",
        "description": "Nombre max d'onglets par Chrome avant d'en lancer un nouveau (concurrence).",
        "operationId": "get_max_tabs_config_max_tabs_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "system"
        ],
        "summary": "Modifier le seuil d'onglets",
        "description": "Change le seuil (persisté en BD, appliqué immédiatement au pool en cours).",
        "operationId": "set_max_tabs_config_max_tabs_put",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MaxTabsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/pay": {
      "post": {
        "tags": [
          "payments"
        ],
        "summary": "Exécuter un paiement",
        "description": "Exécute un paiement via l'agrégateur et le mode demandés.\n\n- **auto** (défaut) : replay d'abord ; bascule navigateur si non concluant\n  (selon `fallback_browser`).\n- **browser** : flux IA complet ; déduit et persiste le template curl.\n- **replay** : rejoue via le template stocké (409 si absent).",
        "operationId": "pay_pay_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PayRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PayResponse"
                }
              }
            }
          },
          "404": {
            "description": "Agrégateur inconnu."
          },
          "400": {
            "description": "Mode invalide."
          },
          "422": {
            "description": "Réseau non supporté (renvoie la liste exacte attendue)."
          },
          "409": {
            "description": "Mode replay sans template (lancer mode=browser d'abord)."
          },
          "502": {
            "description": "Replay échoué et fallback navigateur désactivé."
          },
          "503": {
            "description": "Service de paiement amont temporairement indisponible (code=network_unavailable). Réessayer plus tard."
          }
        }
      }
    },
    "/transactions/{tx_id}/cancel": {
      "post": {
        "tags": [
          "transactions"
        ],
        "summary": "Débloquer une transaction pending",
        "description": "Force une transaction restée **pending** à **cancelled**.\n\nSert à débloquer une transaction coincée (ex: serveur interrompu avant le\nverdict) qui empêcherait un nouveau paiement sur le même numéro\n(`409 pending_exists`). N'agit que sur une ligne encore `pending` — ne\nréécrit jamais un verdict déjà acté.",
        "operationId": "cancel_transaction_transactions__tx_id__cancel_post",
        "parameters": [
          {
            "name": "tx_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Tx Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "404": {
            "description": "Aucune transaction 'pending' avec cet id."
          },
          "503": {
            "description": "Supabase non configuré."
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "MaxTabsRequest": {
        "properties": {
          "max_tabs": {
            "type": "integer",
            "maximum": 200.0,
            "minimum": 1.0,
            "title": "Max Tabs",
            "description": "Nb max d'onglets par instance Chrome.",
            "examples": [
              20
            ]
          }
        },
        "type": "object",
        "required": [
          "max_tabs"
        ],
        "title": "MaxTabsRequest"
      },
      "PayRequest": {
        "properties": {
          "amount": {
            "type": "integer",
            "title": "Amount",
            "description": "Montant en XAF.",
            "examples": [
              25
            ]
          },
          "phone": {
            "type": "string",
            "title": "Phone",
            "description": "Numéro Mobile Money (sans +237).",
            "examples": [
              "696080087"
            ]
          },
          "network": {
            "type": "string",
            "title": "Network",
            "description": "Réseau : Orangemoney ou MTN.",
            "examples": [
              "Orangemoney"
            ]
          },
          "email": {
            "type": "string",
            "title": "Email",
            "description": "Email du payeur.",
            "examples": [
              "client@example.com"
            ]
          },
          "sender_name": {
            "type": "string",
            "title": "Sender Name",
            "description": "Nom affiché de l'émetteur.",
            "default": "Rauvalia"
          },
          "callback_url": {
            "type": "string",
            "title": "Callback Url",
            "description": "URL de callback (défaut: celle de l'agrégateur).",
            "default": ""
          },
          "aggregator": {
            "type": "string",
            "title": "Aggregator",
            "description": "Nom de l'agrégateur (cf. GET /aggregators).",
            "default": "digikuntz"
          },
          "mode": {
            "type": "string",
            "title": "Mode",
            "description": "auto | browser | replay.",
            "default": "auto",
            "examples": [
              "auto"
            ]
          },
          "fallback_browser": {
            "type": "boolean",
            "title": "Fallback Browser",
            "description": "En mode auto : basculer sur le navigateur si le replay est non concluant.",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "amount",
          "phone",
          "network",
          "email"
        ],
        "title": "PayRequest",
        "examples": [
          {
            "aggregator": "digikuntz",
            "amount": 25,
            "email": "client@example.com",
            "fallback_browser": true,
            "mode": "auto",
            "network": "Orangemoney",
            "phone": "696080087"
          }
        ]
      },
      "PayResponse": {
        "properties": {
          "success": {
            "type": "boolean",
            "title": "Success",
            "description": "Vrai si le paiement a abouti."
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "successful | ussd_sent | failed | cancelled | pending.",
            "default": ""
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Message clair pour l'utilisateur final.",
            "default": ""
          },
          "transaction_id": {
            "type": "string",
            "title": "Transaction Id",
            "description": "Référence transaction de l'agrégateur.",
            "default": ""
          },
          "code": {
            "type": "string",
            "title": "Code",
            "description": "Code machine en cas d'erreur (ex. network_unavailable, operator_unavailable). Vide si OK.",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "success"
        ],
        "title": "PayResponse",
        "description": "Vue CLIENT (dev qui intègre l'API) — strictement l'essentiel métier.\n\nTout le détail technique (charge_url, plaintext, curl, trace, tokens…) est\nréservé à l'admin (voir PayResponseDebug + ?debug=true). Ne JAMAIS ajouter de\nchamp interne ici."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  },
  "tags": [
    {
      "name": "system",
      "description": "Santé et introspection du service."
    },
    {
      "name": "payments",
      "description": "Exécution des paiements via les agrégateurs."
    },
    {
      "name": "transactions",
      "description": "Gestion des transactions exposée au client."
    },
    {
      "name": "admin",
      "description": "Audit/debug réservé à l'admin backend (non documenté pour le client)."
    },
    {
      "name": "dev",
      "description": "Outils de développement (pilotage libre, ping LLM)."
    }
  ]
}
