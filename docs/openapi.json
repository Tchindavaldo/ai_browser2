{
  "openapi": "3.1.0",
  "info": {
    "title": "MobileWallet backend",
    "description": "\nBackend **MobileWallet** — un rassemblement d'**agrégateurs** de paiement Mobile Money.\n\nChaque agrégateur (DigiKUNTZ aujourd'hui, d'autres demain) est un module exposant\ndeux capacités :\n\n- **navigateur IA** (`mode=browser`) : un agent Playwright + LLM pilote le checkout,\n  exécute le paiement et **déduit** le « curl replay » (requête `/charge` + `/verify`),\n  persisté comme *template* réutilisable.\n- **curl replay** (`mode=replay`) : rejoue le paiement sans navigateur via le template stocké.\n- **auto** (`mode=auto`, défaut) : tente le replay d'abord, puis bascule sur le navigateur\n  si le replay est non concluant (`fallback_browser`).\n\nToute tentative est auditée (table `transactions`) quand Supabase est configuré.\n",
    "version": "0.2"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Santé du service",
        "description": "Statut du service + liste des agrégateurs enregistrés.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/aggregators": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Agrégateurs disponibles",
        "description": "Liste les agrégateurs et, pour chacun, les réseaux exacts acceptés.",
        "operationId": "list_aggregators_aggregators_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/config/max-tabs": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Seuil d'onglets par navigateur",
        "description": "Nombre max d'onglets par Chrome avant d'en lancer un nouveau (concurrence).",
        "operationId": "get_max_tabs_config_max_tabs_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "system"
        ],
        "summary": "Modifier le seuil d'onglets",
        "description": "Change le seuil (persisté en BD, appliqué immédiatement au pool en cours).",
        "operationId": "set_max_tabs_config_max_tabs_put",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MaxTabsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/pay": {
      "post": {
        "tags": [
          "payments"
        ],
        "summary": "Exécuter un paiement",
        "description": "Exécute un paiement via l'agrégateur et le mode demandés.\n\n- **auto** (défaut) : replay d'abord ; bascule navigateur si non concluant\n  (selon `fallback_browser`).\n- **browser** : flux IA complet ; déduit et persiste le template curl.\n- **replay** : rejoue via le template stocké (409 si absent).",
        "operationId": "pay_pay_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PayRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PayResponse"
                }
              }
            }
          },
          "404": {
            "description": "Agrégateur inconnu."
          },
          "400": {
            "description": "Mode invalide."
          },
          "422": {
            "description": "Réseau non supporté (renvoie la liste exacte attendue)."
          },
          "409": {
            "description": "Mode replay sans template (lancer mode=browser d'abord)."
          },
          "502": {
            "description": "Replay échoué et fallback navigateur désactivé."
          }
        }
      }
    },
    "/transactions": {
      "get": {
        "tags": [
          "transactions"
        ],
        "summary": "Historique des transactions",
        "description": "Dernières transactions auditées (vide si Supabase non configuré).\n\nFiltre optionnel par `aggregator`.",
        "operationId": "list_transactions_transactions_get",
        "parameters": [
          {
            "name": "aggregator",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Aggregator"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/status/{transaction_ref}": {
      "get": {
        "tags": [
          "transactions"
        ],
        "summary": "Statut d'une transaction",
        "description": "Récupère une transaction stockée par sa référence.",
        "operationId": "transaction_status_status__transaction_ref__get",
        "parameters": [
          {
            "name": "transaction_ref",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Transaction Ref"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "404": {
            "description": "Aucune transaction pour cette référence."
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/transactions/{transaction_ref}/trace": {
      "get": {
        "tags": [
          "transactions"
        ],
        "summary": "Trace IA d'une transaction (mode browser)",
        "description": "Renvoie la trace tour-par-tour de l'agent IA pour une transaction browser.\n\nChaque entrée : ce que l'IA a vu (url, nb d'éléments), sa pensée, les actions\njouées, et si l'objectif a été atteint. Vide pour un paiement en mode replay.",
        "operationId": "transaction_trace_transactions__transaction_ref__trace_get",
        "parameters": [
          {
            "name": "transaction_ref",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Transaction Ref"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "404": {
            "description": "Aucune transaction pour cette référence."
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/transactions/{tx_id}/cancel": {
      "post": {
        "tags": [
          "transactions"
        ],
        "summary": "Débloquer une transaction pending",
        "description": "Force une transaction restée **pending** à **cancelled**.\n\nSert à débloquer une transaction coincée (ex: serveur interrompu avant le\nverdict) qui empêcherait un nouveau paiement sur le même numéro\n(`409 pending_exists`). N'agit que sur une ligne encore `pending` — ne\nréécrit jamais un verdict déjà acté.",
        "operationId": "cancel_transaction_transactions__tx_id__cancel_post",
        "parameters": [
          {
            "name": "tx_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Tx Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "404": {
            "description": "Aucune transaction 'pending' avec cet id."
          },
          "503": {
            "description": "Supabase non configuré."
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/aggregators/{name}/template": {
      "get": {
        "tags": [
          "transactions"
        ],
        "summary": "Template curl actif d'un agrégateur",
        "description": "Renvoie le template de replay actif de l'agrégateur (404 si aucun).",
        "operationId": "get_template_aggregators__name__template_get",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "404": {
            "description": "Agrégateur inconnu ou aucun template actif."
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "transactions"
        ],
        "summary": "Ajouter/mettre à jour manuellement le template curl",
        "description": "Ajoute manuellement un template de replay pour l'agrégateur.\n\nPar défaut **append-si-différent** (comme le mode browser) : si identique à\nl'actif, rien n'est ajouté. `force=true` crée toujours une nouvelle version.",
        "operationId": "set_template_aggregators__name__template_post",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Name"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TemplateBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "404": {
            "description": "Agrégateur inconnu."
          },
          "503": {
            "description": "Supabase non configuré (persistance désactivée)."
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/drive": {
      "post": {
        "tags": [
          "dev"
        ],
        "summary": "Pilotage libre du navigateur (dev)",
        "description": "Drive the browser to a URL and let the AI agent handle it.",
        "operationId": "drive_drive_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DriveRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/test-llm": {
      "post": {
        "tags": [
          "dev"
        ],
        "summary": "Ping du LLM (dev)",
        "description": "Quick test: send a simple prompt to DeepSeek and return the response.",
        "operationId": "test_llm_test_llm_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DriveRequest": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url"
          },
          "objective": {
            "type": "string",
            "title": "Objective"
          },
          "phone": {
            "type": "string",
            "title": "Phone",
            "default": ""
          },
          "network": {
            "type": "string",
            "title": "Network",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "url",
          "objective"
        ],
        "title": "DriveRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "MaxTabsRequest": {
        "properties": {
          "max_tabs": {
            "type": "integer",
            "maximum": 200.0,
            "minimum": 1.0,
            "title": "Max Tabs",
            "description": "Nb max d'onglets par instance Chrome.",
            "examples": [
              20
            ]
          }
        },
        "type": "object",
        "required": [
          "max_tabs"
        ],
        "title": "MaxTabsRequest"
      },
      "PayRequest": {
        "properties": {
          "amount": {
            "type": "integer",
            "title": "Amount",
            "description": "Montant en XAF.",
            "examples": [
              25
            ]
          },
          "phone": {
            "type": "string",
            "title": "Phone",
            "description": "Numéro Mobile Money (sans +237).",
            "examples": [
              "696080087"
            ]
          },
          "network": {
            "type": "string",
            "title": "Network",
            "description": "Réseau : Orangemoney ou MTN.",
            "examples": [
              "Orangemoney"
            ]
          },
          "email": {
            "type": "string",
            "title": "Email",
            "description": "Email du payeur.",
            "examples": [
              "client@example.com"
            ]
          },
          "sender_name": {
            "type": "string",
            "title": "Sender Name",
            "description": "Nom affiché de l'émetteur.",
            "default": "Rauvalia"
          },
          "callback_url": {
            "type": "string",
            "title": "Callback Url",
            "description": "URL de callback (défaut: celle de l'agrégateur).",
            "default": ""
          },
          "aggregator": {
            "type": "string",
            "title": "Aggregator",
            "description": "Nom de l'agrégateur (cf. GET /aggregators).",
            "default": "digikuntz"
          },
          "mode": {
            "type": "string",
            "title": "Mode",
            "description": "auto | browser | replay.",
            "default": "auto",
            "examples": [
              "auto"
            ]
          },
          "fallback_browser": {
            "type": "boolean",
            "title": "Fallback Browser",
            "description": "En mode auto : basculer sur le navigateur si le replay est non concluant.",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "amount",
          "phone",
          "network",
          "email"
        ],
        "title": "PayRequest",
        "examples": [
          {
            "aggregator": "digikuntz",
            "amount": 25,
            "email": "client@example.com",
            "fallback_browser": true,
            "mode": "auto",
            "network": "Orangemoney",
            "phone": "696080087"
          }
        ]
      },
      "PayResponse": {
        "properties": {
          "success": {
            "type": "boolean",
            "title": "Success",
            "description": "Vrai si le paiement a abouti."
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Message clair pour l'utilisateur (succès comme échec).",
            "default": ""
          },
          "error": {
            "type": "string",
            "title": "Error",
            "description": "Message d'erreur technique éventuel.",
            "default": ""
          },
          "transaction_id": {
            "type": "string",
            "title": "Transaction Id",
            "description": "Référence transaction de l'agrégateur.",
            "default": ""
          },
          "payment_status": {
            "type": "string",
            "title": "Payment Status",
            "default": ""
          },
          "turns": {
            "type": "integer",
            "title": "Turns",
            "description": "Nombre de tours de l'agent IA (mode browser).",
            "default": 0
          },
          "input_tokens": {
            "type": "integer",
            "title": "Input Tokens",
            "default": 0
          },
          "output_tokens": {
            "type": "integer",
            "title": "Output Tokens",
            "default": 0
          },
          "flutterwave_charge_url": {
            "type": "string",
            "title": "Flutterwave Charge Url",
            "default": ""
          },
          "flutterwave_charge_body": {
            "type": "string",
            "title": "Flutterwave Charge Body",
            "default": ""
          },
          "flutterwave_charge_response": {
            "type": "string",
            "title": "Flutterwave Charge Response",
            "default": ""
          },
          "curl_replay": {
            "type": "string",
            "title": "Curl Replay",
            "description": "Commande curl reproductible déduite.",
            "default": ""
          },
          "plaintext_payload": {
            "type": "string",
            "title": "Plaintext Payload",
            "default": ""
          },
          "public_key": {
            "type": "string",
            "title": "Public Key",
            "default": ""
          },
          "verify_url": {
            "type": "string",
            "title": "Verify Url",
            "default": ""
          },
          "verify_request_body": {
            "type": "string",
            "title": "Verify Request Body",
            "default": ""
          },
          "verify_last_response": {
            "type": "string",
            "title": "Verify Last Response",
            "default": ""
          },
          "verify_curl": {
            "type": "string",
            "title": "Verify Curl",
            "default": ""
          },
          "final_status": {
            "type": "string",
            "title": "Final Status",
            "description": "successful | failed | cancelled | pending | unknown.",
            "default": ""
          },
          "final_message": {
            "type": "string",
            "title": "Final Message",
            "description": "Message clair pour l'utilisateur final.",
            "default": ""
          },
          "error_signals": {
            "additionalProperties": true,
            "type": "object",
            "title": "Error Signals",
            "default": {}
          },
          "captured_requests": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Captured Requests",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "success"
        ],
        "title": "PayResponse"
      },
      "TemplateBody": {
        "properties": {
          "charge_url": {
            "type": "string",
            "title": "Charge Url",
            "default": ""
          },
          "verify_url": {
            "type": "string",
            "title": "Verify Url",
            "default": ""
          },
          "init_url": {
            "type": "string",
            "title": "Init Url",
            "default": ""
          },
          "upgrade_url": {
            "type": "string",
            "title": "Upgrade Url",
            "default": ""
          },
          "hosted_pay_url": {
            "type": "string",
            "title": "Hosted Pay Url",
            "default": ""
          },
          "headers": {
            "additionalProperties": true,
            "type": "object",
            "title": "Headers"
          },
          "payload_skeleton": {
            "additionalProperties": true,
            "type": "object",
            "title": "Payload Skeleton"
          },
          "public_key_rsa": {
            "type": "string",
            "title": "Public Key Rsa",
            "default": ""
          },
          "flw_pub_key": {
            "type": "string",
            "title": "Flw Pub Key",
            "default": ""
          },
          "force": {
            "type": "boolean",
            "title": "Force",
            "description": "Forcer une nouvelle version même si identique à l'actif.",
            "default": false
          }
        },
        "type": "object",
        "title": "TemplateBody",
        "description": "Champs du curl template (tous optionnels — seuls ceux fournis sont posés)."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  },
  "tags": [
    {
      "name": "system",
      "description": "Santé et introspection du service."
    },
    {
      "name": "payments",
      "description": "Exécution des paiements via les agrégateurs."
    },
    {
      "name": "transactions",
      "description": "Historique et statut des transactions (Supabase)."
    },
    {
      "name": "dev",
      "description": "Outils de développement (pilotage libre, ping LLM)."
    }
  ]
}
