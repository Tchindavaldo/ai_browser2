# MobileWallet backend — environment configuration.
# Copy to .env (gitignored) and fill with real values.

# --- DigiKUNTZ aggregator ---
DIGIKUNTZ_BASE=https://app.digikuntz.com/dev
DIGIKUNTZ_USER_ID=
DIGIKUNTZ_SECRET=
DIGIKUNTZ_CALLBACK_URL=https://app.digikuntz.com/callback

# --- Flutterwave (used by the DigiKUNTZ replay flow; DB template overrides when present) ---
FLW_PUB_KEY=
FLW_CHARGE_URL=https://api.ravepay.co/flwv3-pug/getpaidx/api/charge?use_polling=1
FLW_VERIFY_URL=https://api.ravepay.co/flwv3-pug/getpaidx/api/verify/mpesa
FLW_INIT_URL=https://api.ravepay.co/v3/checkout/initialize
FLW_UPGRADE_URL=https://api.ravepay.co/v2/checkout/upgrade

# --- LLM (DeepSeek) ---
DEEPSEEK_API_KEY=
LLM_MODEL=deepseek-v4-flash

# --- Supabase ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Runtime ---
HEADLESS=1
PORT=7332

# --- Délai opérateur / fenêtre de retry (secondes) ---
# Délai avant qu'un opérateur Mobile Money auto-annule une transaction non
# validée. Diffère par opérateur : Orange ~17 min, MTN ~10 min (+marge).
# Sert au polling verify, au plafond de la boucle navigateur, et à la garde
# anti-doublon (un 'cancelled' bloque le numéro pendant cette fenêtre).
RETRY_WINDOW_ORANGE_S=1020
RETRY_WINDOW_MTN_S=600
RETRY_WINDOW_S=1020          # fallback pour un réseau inconnu

# --- Concurrence navigateur ---
# Nb max de sessions (onglets isolés) par Chrome avant d'en lancer une autre.
# Surchargé par la BD (app_settings) et l'API PUT /config/max-tabs.
MAX_TABS_PER_BROWSER=20
