# MobileWallet backend — environment configuration.
# Copy to .env (gitignored) and fill with real values.

# --- DigiKUNTZ aggregator ---
DIGIKUNTZ_BASE=https://app.digikuntz.com/dev
DIGIKUNTZ_USER_ID=
DIGIKUNTZ_SECRET=
DIGIKUNTZ_CALLBACK_URL=https://app.digikuntz.com/callback

# --- Flutterwave (used by the DigiKUNTZ replay flow; DB template overrides when present) ---
FLW_PUB_KEY=
FLW_CHARGE_URL=https://api.ravepay.co/flwv3-pug/getpaidx/api/charge?use_polling=1
FLW_VERIFY_URL=https://api.ravepay.co/flwv3-pug/getpaidx/api/verify/mpesa
FLW_INIT_URL=https://api.ravepay.co/v3/checkout/initialize
FLW_UPGRADE_URL=https://api.ravepay.co/v2/checkout/upgrade

# --- LLM (DeepSeek) ---
DEEPSEEK_API_KEY=
LLM_MODEL=deepseek-v4-flash

# --- Supabase ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Runtime ---
HEADLESS=1
PORT=7332
